# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/family_trees

# JWT — shared HS256 secret. The same value MUST be set on:
#   - photos.mytrees.family
#   - cinderella.photography backend
# Generate via `openssl rand -base64 48`.
JWT_SECRET=gvs0EUdIp5lhW2gAgSvTGI5+xB6rLO/I6KACAUHs3cEQuf8M69dKywBkbqLtk91K

# Email (Resend) — required for production OTP delivery
RESEND_API_KEY=
EMAIL_FROM=MyTrees <noreply@mytrees.family>

# --- Photos media service ---
# Where to upload media on behalf of users adding pictures to a person.
GPAPICS_URL=http://localhost:3000
GPAPICS_API_KEY=ft-dev-key-change-me-in-production

# --- OAuth2 provider clients ---
# mytrees.family acts as the IdP for the rest of the ecosystem. Each client
# has its own secret. Generate via `openssl rand -base64 32`.

# photos.mytrees.family
PHOTOS_OAUTH_CLIENT_SECRET=
# Override redirect URIs (comma-separated). Default includes:
#   https://photos.mytrees.family/auth/callback, http://localhost:3000/auth/callback
PHOTOS_OAUTH_REDIRECT_URIS=

# cinderella.photography
CINDERELLA_OAUTH_CLIENT_SECRET=gf/RaVf0VmQ1fq0YZTVh7909LLvlMPXDjKAXNwx0Pak=
# Override redirect URIs (comma-separated). Default includes:
#   https://cinderella.photography/api/auth/callback, http://localhost:3001/api/auth/callback
CINDERELLA_OAUTH_REDIRECT_URIS=
